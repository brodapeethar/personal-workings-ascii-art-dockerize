# -------- Build Stage --------
FROM golang:1.22-alpine AS builder

WORKDIR /app

# Install git (sometimes needed for private modules)
RUN apk add --no-cache git

# Cache dependencies
COPY go.mod ./
RUN go mod download

# Copy source code
COPY . .

# Build the binary
RUN CGO_ENABLED=0 GOOS=linux go build -o ascii-art-web-dockerize

# -------- Run Stage --------
FROM alpine:latest

WORKDIR /app

# Install required packages (for healthcheck)
RUN apk --no-cache add ca-certificates wget

# Create non-root user
RUN addgroup -g 1000 appuser && \
    adduser -D -u 1000 -G appuser appuser

# Copy binary and files from builder
COPY --from=builder /app/ascii-art-web-dockerize .
COPY --from=builder /app/banners ./banners
COPY --from=builder /app/templates ./templates
COPY --from=builder /app/static ./static

# Set ownership to non-root user
RUN chown -R appuser:appuser /app

# Switch to non-root user
USER appuser

# Expose port
EXPOSE 3000

# Healthcheck
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://localhost:3000/ || exit 1

# Run app
CMD ["./ascii-art-web-dockerize"]
